PORT=4000
CORS_ORIGIN=http://localhost:1234

# Required for /api/chat. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required for /api/contact email notifications. Use a Gmail address + an
# App Password (not your normal password): https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=

# Optional override; defaults to server/data/contacts.sqlite
DB_PATH=
